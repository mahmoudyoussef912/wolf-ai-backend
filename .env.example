SECRET_KEY=replace-with-random-secret
JWT_SECRET=replace-with-random-jwt-secret
ADMIN_PASS=replace-with-strong-admin-password

# Render Postgres connection string (auto-injected if using render.yaml)
DATABASE_URL=

# Set this to your Vercel frontend URL after deployment
# Example: https://your-app.vercel.app
CORS_ORIGINS=http://localhost:3000

# Optional API keys
GROQ_API_KEY=
HF_API_TOKEN=
OPENROUTER_API_KEY=

# Optional Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
